---
const targetDate = "2026-07-25T14:00:00";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>La Velada del Año</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body>
    <main>
      <img src="/logo.png" alt="La Velada del Año" class="logo" />
      <div class="social-links">
        <a href="https://www.twitch.tv/ibai" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Twitch">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
        </a>
        <a href="https://www.youtube.com/@IbaiLlanos" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@ibai" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
      <div class="countdown" id="countdown">
        <div class="unit">
          <span class="number" id="days">00</span>
          <span class="label">DÍAS</span>
        </div>
        <span class="separator">:</span>
        <div class="unit">
          <span class="number" id="hours">00</span>
          <span class="label">HORAS</span>
        </div>
        <span class="separator">:</span>
        <div class="unit">
          <span class="number" id="minutes">00</span>
          <span class="label">MIN</span>
        </div>
        <span class="separator">:</span>
        <div class="unit">
          <span class="number" id="seconds">00</span>
          <span class="label">SEG</span>
        </div>
      </div>
      <p class="location">
  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
  ESTADIO DE LA CARTUJA, SEVILLA
</p>
      <div class="buttons">
        <button class="btn btn-soldout">ENTRADAS AGOTADAS</button>
        <a
          href="https://www.google.com/calendar/render?action=TEMPLATE&text=La+Velada+del+A%C3%B1o&dates=20260725T120000Z/20260725T200000Z"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-schedule"
          >AGENDAR FECHA</a
        >
      </div>
    </main>

    <style is:global>
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-black.woff2") format("woff2");
        font-weight: 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-extrabold.woff2") format("woff2");
        font-weight: 800;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Cinzel";
        src: url("/fonts/cinzel-semibold.woff2") format("woff2");
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        background: #0a0a0f;
        background-image: url("/background-1280.webp");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Cinzel", serif;
        position: relative;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background: radial-gradient(
          ellipse at center,
          rgba(0, 0, 0, 0.2) 0%,
          rgba(0, 0, 0, 0.85) 100%
        );
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 2rem 1.5rem;
        max-width: 800px;
        width: 100%;
      }

      .logo {
        display: block;
        margin: 0 auto 2rem;
        max-width: 380px;
        width: 90%;
        height: auto;
        filter: drop-shadow(0 0 40px rgba(255, 215, 0, 0.15));
        animation: fadeInUp 1s ease-out 0.3s both;
      }

      .social-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
        animation: fadeInUp 1s ease-out 0.5s both;
      }

      .social-link {
        color: #fff;
        width: 40px;
        height: 40px;
        transition: color 0.3s, transform 0.3s, background 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.5);
        border-radius: 50%;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .social-link:hover {
        color: #0a0a0f;
        background: #ffd700;
        transform: translateY(-3px) scale(1.1);
        border-color: #ffd700;
      }

      .social-link svg {
        width: 20px;
        height: 20px;
      }

      .countdown {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        margin-bottom: 0.75rem;
        animation: fadeInUp 1s ease-out 0.7s both;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(6px);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      .unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 80px;
      }

      .unit .number {
        font-family: "Cinzel", serif;
        font-weight: 900;
        font-size: 4.5rem;
        line-height: 1;
        color: #ffffff;
        text-shadow:
          0 0 10px rgba(255, 215, 0, 0.4),
          0 0 40px rgba(0, 0, 0, 0.8),
          0 2px 4px rgba(0, 0, 0, 0.9);
      }

      .unit .label {
        font-family: "Cinzel", serif;
        font-weight: 600;
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 2px;
        margin-top: 0.25rem;
        text-shadow: 0 1px 6px rgba(0, 0, 0, 0.9);
      }

      .separator {
        font-family: "Cinzel", serif;
        font-weight: 900;
        font-size: 4rem;
        color: #ffd700;
        margin-bottom: 1.5rem;
        opacity: 0.6;
      }

      .location {
        font-family: "Cinzel", serif;
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
        animation: fadeInUp 1s ease-out 0.9s both;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .location svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }

      .buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeInUp 1s ease-out 1.1s both;
      }

      .btn {
        font-family: "Cinzel", serif;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 2px;
        padding: 1rem 2.5rem;
        border-radius: 50px;
        border: none;
        cursor: default;
        text-transform: uppercase;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
        display: inline-block;
      }

      .btn-soldout {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.4);
      }

      .btn-schedule {
        background: linear-gradient(135deg, #ffd700, #ffaa00);
        color: #0a0a0f;
        cursor: pointer;
      }

      .btn-schedule:hover {
        transform: scale(1.05);
        box-shadow: 0 0 30px rgba(255, 215, 0, 0.4);
      }

      .unit .number {
        animation: pulseGlow 2s ease-in-out infinite;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes pulseGlow {
        0%, 100% {
          text-shadow: 0 0 20px rgba(255, 215, 0, 0.2);
        }
        50% {
          text-shadow: 0 0 40px rgba(255, 215, 0, 0.5);
        }
      }

      @media (max-width: 480px) {
        .unit .number {
          font-size: 3rem;
        }
        .unit {
          min-width: 60px;
        }
        .separator {
          font-size: 2.5rem;
        }
        .logo {
          max-width: 280px;
        }
        .btn {
          font-size: 0.75rem;
          padding: 0.85rem 1.8rem;
        }
        .countdown {
          padding: 0.75rem 1rem;
          max-width: 100%;
        }
        .social-link {
          width: 36px;
          height: 36px;
        }
        .social-link svg {
          width: 18px;
          height: 18px;
        }
        .social-links {
          gap: 1rem;
          margin-bottom: 2rem;
        }
      }
    </style>

    <script>
      const target = new Date("2026-07-25T14:00:00").getTime();

      function update() {
        const now = Date.now();
        const diff = Math.max(0, target - now);

        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        document.getElementById("days").textContent = String(d).padStart(2, "0");
        document.getElementById("hours").textContent = String(h).padStart(2, "0");
        document.getElementById("minutes").textContent = String(m).padStart(2, "0");
        document.getElementById("seconds").textContent = String(s).padStart(2, "0");
      }

      update();
      setInterval(update, 1000);
    </script>
  </body>
</html>
